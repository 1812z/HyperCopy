{
  "name": "baiduyun",
  "category": "link",
  "actionMode": "parse_and_open",
  "matchRegex": ".*pan\\.baidu\\.com.*",
  "extractionRegexes": [
    "\\/1(.*)"
  ],
  "target": {
    "type": "url",
    "template": "bdnetdisk://n/action.SHARE_LINK?m_n_v=8.3.0&surl=${r1}",
    "packageName": "com.baidu.netdisk"
  }
}