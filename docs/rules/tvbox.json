{
  "name": "tvbox",
  "category": "link",
  "actionMode": "direct_open",
  "matchRegex": ".*cloud\\.189\\.cn.*|.*pan\\.quark\\.cn.*",
  "target": {
    "type": "url",
    "template": "intent:#Intent;launchFlags=0x10000000;component=com.fongmi.android.tv/.ui.activity.VideoActivity;S.id=${url:input};S.key=push_agent;S.name=${url:input};B.collect=false;B.download=false;end",
    "packageName": "com.fongmi.android.tv"
  }
}